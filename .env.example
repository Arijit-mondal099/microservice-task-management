# Template for the root .env. Copy to .env and fill in real values.
# Compose reads .env automatically at parse time (same directory as docker-compose.yml).

# --- Mongo root credentials ---
# These initialize the mongodb container AND build the auth section of every
# service's MONGODB_URI. Changing them here changes both sides.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=changeme

# --- user-service ---
# Port for both host mapping and the container's internal listener.
USER_SERVICE_PORT=4000
# Database name appended to the Mongo URI path.
USER_SERVICE_DB=users

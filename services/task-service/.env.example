PORT=4001
NODE_ENV=development

# Local dev URI — credentials must match docker-compose.yml at repo root.
# authSource=admin is required because the root user lives in the admin DB.
MONGODB_URI=mongodb://USER:PASSWORD@localhost:27017/tasks?authSource=admin

# Local dev RabbitMQ URI — credentials must match docker-compose.yml at repo root.
RABBITMQ_URI=amqp://USER:PASSWORD@localhost:5672
